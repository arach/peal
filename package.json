{
  "name": "@peal-sounds/peal",
  "version": "0.2.3",
  "bin": {
    "peal": "./cli/index.js"
  },
  "description": "Professional UI sounds for web apps - CLI to manage sounds, thin Howler.js wrapper to play them",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "cli"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "build:lib": "tsup src/index.ts --format cjs,esm --dts --tsconfig tsconfig.lib.json",
    "build:web": "next build",
    "prebuild:static": "node scripts/prepare-static-build.js",
    "build:static": "BUILD_STATIC=true NEXT_PUBLIC_BUILD_STATIC=true next build",
    "predev": "node scripts/setup-directories.js",
    "dev": "next dev --port 3001",
    "dev:lib": "tsup src/index.ts --format cjs,esm --dts --watch",
    "start": "next start",
    "test": "vitest",
    "lint": "eslint .",
    "lint:lib": "eslint src",
    "prepublishOnly": "cp README.npm.md README.md && pnpm build:lib",
    "postpublish": "git checkout README.md",
    "cli": "node cli/index.js",
    "cli:generate-sounds": "node cli/generate-cli-sounds.cjs",
    "credentials": "node scripts/check-credentials.mjs",
    "seed:message-beds": "node scripts/seed-message-beds.mjs",
    "publish:npm": "node scripts/publish-npm.mjs",
    "publish:npm:arach": "node scripts/publish-npm.mjs --only @arach/peal"
  },
  "keywords": [
    "sound",
    "audio",
    "effects",
    "ui",
    "web-audio"
  ],
  "author": "arach",
  "repository": {
    "type": "git",
    "url": "https://github.com/arach/peal.git"
  },
  "homepage": "https://github.com/arach/peal#readme",
  "bugs": {
    "url": "https://github.com/arach/peal/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/howler": "^2.2.13",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.9",
    "framer-motion": "^12.42.0",
    "jszip": "^3.10.1",
    "next": "16.2.9",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "puppeteer": "^25.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "zustand": "^5.0.14"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@earendil-works/pi-ai": "^0.74.0",
    "@hudsonkit/ai": "file:../hudson/packages/web/ai-backends",
    "@lezer/highlight": "^1.2.3",
    "@phosphor-icons/react": "^2.1.10",
    "@pierre/diffs": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.17",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@voxd/client": "^0.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^7.0.6",
    "chalk": "^5.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^15.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "howler": "^2.2.4",
    "hudsonkit": "file:../hudson/packages/web/hudsonkit",
    "inquirer": "^14.0.2",
    "lucide-react": "^1.22.0",
    "node-ffmpeg-installer": "^1.1.2",
    "ora": "^9.4.1",
    "tailwind-merge": "^3.6.0",
    "youtube-dl-exec": "^3.1.8",
    "yt-dlp-wrap": "^2.3.12",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.9"
}
