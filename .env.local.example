# Peal local development — copy to .env.local and fill in keys.
# Restart `pnpm dev` (port 3001) after changing env files.
#
# Credential resolution (first match wins):
#   1. process.env already set in the shell
#   2. PEAL_ENV_FILE (optional path to a dotenv file)
#   3. ../.env.local  — shared dev keys next to the peal repo (auto-loaded)
#   4. .env.local     — this project (overrides shared for the same key)
#   5. pi-ai getEnvApiKey() for provider-backed keys
#
# Run `pnpm credentials` to see what is configured.

# Optional: point at a custom dotenv file
# PEAL_ENV_FILE=/Users/you/dev/.env.local

# AI Sound Designer (peal-studio via Hudson / pi-ai)
MINIMAX_API_KEY=

# Voice studio — OpenAI TTS (tts-1, tts-1-hd)
OPENAI_API_KEY=

# Voice studio — Groq PlayAI TTS (playai-tts, playai-tts-arabic)
GROQ_API_KEY=